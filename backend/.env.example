# ============================================
# FasoSuku Backend - Environment Configuration
# ============================================

# Environment
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# MongoDB Configuration
MONGODB_URI=mongodb://admin:FasoSuku2024!@localhost:27017/fasosuku?authSource=admin
MONGODB_USER=admin
MONGODB_PASSWORD=FasoSuku2024!
MONGODB_DATABASE=fasosuku

# Server Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:8080,http://localhost:5173
TRUST_PROXY=1

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_absolutely_must
JWT_EXPIRE=24h
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production_absolutely_must
JWT_REFRESH_EXPIRE=7d

# OTP/SMS Configuration
OTP_EXPIRY=5m
OTP_MAX_ATTEMPTS=3
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Alternative: Nexmo/Vonage
# SMS_PROVIDER=nexmo
# NEXMO_API_KEY=your_nexmo_api_key
# NEXMO_API_SECRET=your_nexmo_api_secret

# Payment Gateway Configuration
PAYMENT_PROVIDER=cinetpay
CINETPAY_API_KEY=your_cinetpay_api_key
CINETPAY_SECRET_KEY=your_cinetpay_secret_key
PAYMENT_WEBHOOK_SECRET=your_webhook_secret_key_must_match_provider
PLATFORM_COMMISSION_PERCENTAGE=20
CURRENCY=XOF

# Alternative Payment Providers
# PAYMENT_PROVIDER=paystack
# PAYSTACK_PUBLIC_KEY=your_paystack_public_key
# PAYSTACK_SECRET_KEY=your_paystack_secret_key

# AWS S3 (File Storage)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=fasosuku-files-prod
AWS_REGION=eu-west-1
AWS_S3_URL=https://fasosuku-files-prod.s3.amazonaws.com
MAX_FILE_UPLOAD_SIZE=52428800

# Alternative: DigitalOcean Spaces
# DO_SPACES_KEY=your_do_key
# DO_SPACES_SECRET=your_do_secret
# DO_SPACES_BUCKET=fasosuku-prod
# DO_SPACES_ENDPOINT=sfo3.digitaloceanspaces.com
# DO_SPACES_REGION=sfo3

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Email Configuration
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@fasosuku.ml
EMAIL_FROM_NAME=FasoSuku Team

# Alternative: Mailgun
# EMAIL_PROVIDER=mailgun
# MAILGUN_API_KEY=your_mailgun_api_key
# MAILGUN_DOMAIN=mail.fasosuku.ml

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# Security
BCRYPT_ROUNDS=10
SESSION_SECRET=your_session_secret_key_change_this
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_ENABLED=true

# Admin Configuration
ADMIN_EMAIL=admin@fasosuku.ml
ADMIN_PASSWORD=change_this_password_immediately_after_first_login
ADMIN_DEFAULT_USERNAME=admin

# Features
ENABLE_STUDENT_REGISTRATION=true
ENABLE_TEACHER_REGISTRATION=true
ENABLE_PAYMENT_PROCESSING=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR_AUTH=false
ENABLE_ANALYTICS=true

# Watermark Configuration
WATERMARK_OPACITY=0.08
WATERMARK_ANGLE=-45
WATERMARK_FONT_SIZE=24
WATERMARK_REPEAT_SPACING=200

# URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:5000
API_BASE_PATH=/api/v1

# Developer Options (disable in production)
DEBUG=false
SEED_DATABASE=false
ALLOW_TEST_USERS=true

# Notification
NOTIFICATION_SERVICE=firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Analytics (Sentry)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Mobile Operator Integrations
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_SECRET=
MOOV_MONEY_API_KEY=
MOOV_MONEY_SECRET=
WAVE_API_KEY=
WAVE_SECRET=
