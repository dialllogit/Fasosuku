{
  "name": "fasosuku-backend",
  "version": "1.0.0",
  "description": "Backend API for FasoSuku - Academic Digital Library",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NODE_ENV=test jest --detectOpenHandles",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .js",
    "format": "prettier --write src/**/*.js",
    "seed": "node scripts/seedDB.js",
    "migrate": "node scripts/migrate.js"
  },
  "keywords": [
    "education",
    "marketplace",
    "micropayment",
    "mali",
    "pwa"
  ],
  "author": "Diallo Logit",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^7.0.0",
    "express-mongo-sanitize": "^2.2.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.0",
    "joi": "^17.11.0",
    "axios": "^1.5.0",
    "redis": "^4.6.11",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "multer": "^1.4.5-lts.1",
    "aws-sdk": "^2.1505.0",
    "pdf-parse": "^1.1.1",
    "sharp": "^0.32.6",
    "nodemailer": "^6.9.7",
    "twilio": "^3.97.0",
    "crypto": "^1.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.50.0",
    "prettier": "^3.0.3"
  }
}
