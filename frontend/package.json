    "vite": "^4.5.0",
    "vitest": "^0.34.6",
    "@vue/test-utils": "^2.4.1",
    "@testing-library/vue": "^8.0.1",
    "eslint": "^8.50.0",
    "eslint-plugin-vue": "^9.17.0",
