# ============================================
# FasoSuku Frontend - Environment Configuration
# ============================================

# API Configuration
VITE_API_URL=http://localhost:5000
VITE_API_BASE_PATH=/api/v1
VITE_API_TIMEOUT=30000

# App Configuration
VITE_APP_NAME=FasoSuku
VITE_APP_TITLE=FasoSuku - Bibliothèque Numérique du Mali
VITE_APP_DESCRIPTION=La marketplace académique sécurisée du Mali pour enseignants et étudiants
VITE_APP_LOGO=https://fasosuku.ml/logo.png

# Feature Flags
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_SERVICE_WORKER=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_PAYMENT_PROCESSING=true

# Payment Configuration
VITE_PAYMENT_PROVIDER=cinetpay
VITE_PAYMENT_PUBLIC_KEY=your_payment_public_key_for_frontend
VITE_PAYMENT_SANDBOX_MODE=true

# Analytics
VITE_GOOGLE_ANALYTICS_ID=
VITE_SENTRY_DSN=

# Environment
VITE_ENV=development
VITE_DEBUG=true
VITE_LOG_LEVEL=debug

# PWA Configuration
VITE_PWA_ENABLED=true
VITE_PWA_DISPLAY=standalone
VITE_PWA_THEME_COLOR=#1e40af
VITE_PWA_BACKGROUND_COLOR=#ffffff

# Security
VITE_ENABLE_CSP=true
VITE_ENABLE_HTTPS_REDIRECT=false

# Cache Duration (in milliseconds)
VITE_CACHE_DURATION_BOOKS=3600000
VITE_CACHE_DURATION_USER=300000
VITE_CACHE_DURATION_CATALOG=1800000
