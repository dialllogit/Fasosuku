{
  "name": "fasosuku",
  "version": "1.0.0",
  "description": "La Bibliothèque Numérique des Chercheurs du Mali - PWA Marketplace pour Micro-paiement",
  "main": "backend/server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && nodemon server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "start": "node backend/server.js",
    "test": "npm run test:backend",
    "test:backend": "cd backend && npm run test",
    "test:frontend": "cd frontend && npm run test",
    "test:e2e": "cd frontend && npm run test:e2e",
    "test:coverage": "cd backend && npm run test:coverage",
    "lint": "eslint . --ext .js,.jsx,.vue",
    "format": "prettier --write \"**/*.{js,json,md,vue,css}\"",
    "db:seed": "cd backend && node scripts/seedDB.js",
    "db:migrate": "cd backend && npm run migrate",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build": "docker-compose build",
    "docker:clean": "docker-compose down -v"
  },
  "keywords": [
    "mali",
    "education",
    "pwa",
    "marketplace",
    "micropayment",
    "mobile-money",
    "vue",
    "nodejs",
    "mongodb"
  ],
  "author": "Diallo Logit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dialllogit/FasoSuku.git"
  },
  "bugs": {
    "url": "https://github.com/dialllogit/FasoSuku/issues"
  },
  "homepage": "https://github.com/dialllogit/FasoSuku#readme",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "devDependencies": {
    "concurrently": "^8.2.0",
    "prettier": "^3.0.0",
    "eslint": "^8.48.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-vue": "^9.17.0"
  }
}
